{
  "expo": {
    "name": "Keel",
    "slug": "keel",
    "version": "1.0.0",
    "scheme": "com.keelapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0057b8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.uk.keelapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Keel uses the camera to scan receipts and documents.",
        "NSCalendarsUsageDescription": "Keel adds tax deadlines to your calendar."
      }
    },
    "android": {
      "package": "co.uk.keelapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0057b8"
      },
      "permissions": [
        "CAMERA",
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Keel uses the camera to scan receipts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0057b8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
